<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ontology.platform.infrastructure.persistence.NotificationDefinitionPOMapper">
    <select id="selectByOntologyId" resultType="com.ontology.platform.infrastructure.persistence.NotificationDefinitionPO">
        SELECT * FROM notification_definition WHERE ontology_id = #{ontologyId} AND (deleted IS NULL OR deleted = FALSE)
    </select>
</mapper>
