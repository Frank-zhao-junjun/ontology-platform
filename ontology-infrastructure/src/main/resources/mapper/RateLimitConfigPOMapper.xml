<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ontology.platform.infrastructure.persistence.RateLimitConfigPOMapper">

    <select id="selectByScope" resultType="com.ontology.platform.infrastructure.persistence.RateLimitConfigPO">
        SELECT * FROM rate_limit_config
        WHERE scope_type = #{scopeType}
          AND scope_value = #{scopeValue}
        LIMIT 1
    </select>

</mapper>
