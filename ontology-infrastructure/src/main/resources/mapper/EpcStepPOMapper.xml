<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ontology.platform.infrastructure.persistence.EpcStepPOMapper">
    <select id="selectByOntologyId" resultType="com.ontology.platform.infrastructure.persistence.EpcStepPO">
        SELECT * FROM epc_step WHERE ontology_id = #{ontologyId}
    </select>
    <select id="selectByOntologyIdAndFlowName" resultType="com.ontology.platform.infrastructure.persistence.EpcStepPO">
        SELECT * FROM epc_step WHERE ontology_id = #{ontologyId} AND flow_name = #{flowName} ORDER BY step_order ASC
    </select>
    <select id="selectByFlowNameOrderByStepOrder" resultType="com.ontology.platform.infrastructure.persistence.EpcStepPO">
        SELECT * FROM epc_step WHERE flow_name = #{flowName} ORDER BY step_order ASC
    </select>
</mapper>
