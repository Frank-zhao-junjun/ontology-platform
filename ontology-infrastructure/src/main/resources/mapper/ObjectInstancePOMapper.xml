<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ontology.platform.infrastructure.persistence.ObjectInstancePOMapper">

    <resultMap id="BaseResultMap" type="com.ontology.platform.infrastructure.persistence.ObjectInstancePO">
        <id column="id" property="id" jdbcType="VARCHAR"/>
        <result column="ontology_id" property="ontologyId" jdbcType="VARCHAR"/>
        <result column="object_type_id" property="objectTypeId" jdbcType="VARCHAR"/>
        <result column="primary_key_value" property="primaryKeyValue" jdbcType="VARCHAR"/>
        <result column="core_data" property="coreData" jdbcType="VARCHAR"/>
        <result column="extended_data" property="extendedData" jdbcType="VARCHAR"/>
        <result column="created_at" property="createdAt" jdbcType="TIMESTAMP"/>
        <result column="updated_at" property="updatedAt" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, ontology_id, object_type_id, primary_key_value, core_data, extended_data, created_at, updated_at
    </sql>

    <select id="selectByObjectTypeId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM object_instance
        WHERE object_type_id = #{objectTypeId}
        ORDER BY created_at ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByObjectTypeId" resultType="long">
        SELECT COUNT(*) FROM object_instance
        WHERE object_type_id = #{objectTypeId}
    </select>

    <select id="selectByObjectTypeIdAndPrimaryKeyValue" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM object_instance
        WHERE object_type_id = #{objectTypeId} AND primary_key_value = #{primaryKeyValue}
    </select>

</mapper>
