<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ontology.platform.infrastructure.persistence.RolePermissionPOMapper">
    <select id="selectByRoleId" resultType="com.ontology.platform.infrastructure.persistence.RolePermissionPO">
        SELECT * FROM role_permission WHERE role_id = #{roleId}
    </select>
    <select id="selectByDomain" resultType="com.ontology.platform.infrastructure.persistence.RolePermissionPO">
        SELECT * FROM role_permission WHERE domain = #{domain}
    </select>
</mapper>
