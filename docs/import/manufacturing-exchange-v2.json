{
  "apiVersion": "ontology.platform/v2",
  "kind": "OntologyExchange",
  "metadata": {
    "id": "manufacturing-ontology",
    "version": "0.1.0",
    "name": "生产制造本体",
    "displayName": "Manufacturing Ontology",
    "description": "MVP 制造域参考模型（生产订单 / 物料 / BOM / 工艺路线）— 6 实体 import 夹具",
    "source": "ontology-designer",
    "status": "draft",
    "projectId": "manufacturing-project",
    "exportedAt": "2026-06-19T16:00:00.000Z",
    "exporterVersion": "2.0.0"
  },
  "spec": {
    "project": {
      "id": "manufacturing-project",
      "name": "生产制造本体",
      "description": "MVP 制造域参考模型",
      "domain": {
        "id": "domain-manufacturing",
        "name": "生产制造",
        "nameEn": "Manufacturing",
        "description": "生产执行与工单生命周期"
      },
      "dataModel": {
        "id": "dm-manufacturing",
        "name": "生产制造数据模型",
        "version": "0.1.0",
        "domain": "domain-manufacturing",
        "projects": [
          {
            "id": "proj-manufacturing",
            "name": "生产制造",
            "nameEn": "ManufacturingMgmt",
            "description": "生产制造项目"
          }
        ],
        "businessScenarios": [
          {
            "id": "scenario-mts",
            "name": "面向库存生产",
            "nameEn": "MakeToStock",
            "description": "按库存补货驱动生产",
            "projectId": "manufacturing-project"
          },
          {
            "id": "scenario-mto",
            "name": "面向订单生产",
            "nameEn": "MakeToOrder",
            "description": "严格按销售订单驱动",
            "projectId": "manufacturing-project"
          }
        ],
        "entities": [
          {
            "id": "production-order",
            "name": "生产订单",
            "nameEn": "ProductionOrder",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "description": "核心生产执行单据",
            "entityRole": "aggregate_root",
            "attributes": [
              { "id": "attr-order-id", "name": "生产订单号", "nameEn": "order_id", "dataType": "string", "required": true },
              { "id": "attr-order-type", "name": "订单类型", "nameEn": "order_type", "dataType": "enum", "required": true, "enumRef": "order-type-enum" },
              { "id": "attr-status", "name": "订单状态", "nameEn": "status", "dataType": "enum", "required": true, "enumRef": "order-status-enum" },
              { "id": "attr-planned-qty", "name": "计划数量", "nameEn": "planned_qty", "dataType": "decimal", "required": true },
              { "id": "attr-cost-price", "name": "成本价", "nameEn": "cost_price", "dataType": "decimal", "required": false }
            ],
            "relations": [
              {
                "id": "rel-po-bom",
                "name": "引用BOM",
                "type": "many_to_one",
                "targetEntity": "bom",
                "description": "生产订单引用的物料清单"
              }
            ]
          },
          {
            "id": "operation",
            "name": "工序",
            "nameEn": "Operation",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "entityRole": "child_entity",
            "parentAggregateId": "production-order",
            "description": "生产订单的工序明细",
            "attributes": [
              { "id": "attr-op-number", "name": "工序号", "nameEn": "op_number", "dataType": "integer", "required": true }
            ],
            "relations": []
          },
          {
            "id": "material",
            "name": "物料",
            "nameEn": "Material",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "entityRole": "aggregate_root",
            "description": "生产用物料主数据",
            "attributes": [
              { "id": "attr-material-code", "name": "物料编码", "nameEn": "material_code", "dataType": "string", "required": true }
            ],
            "relations": []
          },
          {
            "id": "bom",
            "name": "BOM",
            "nameEn": "BillOfMaterial",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "entityRole": "aggregate_root",
            "description": "物料清单",
            "attributes": [],
            "relations": []
          },
          {
            "id": "routing",
            "name": "工艺路线",
            "nameEn": "Routing",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "entityRole": "aggregate_root",
            "description": "工艺路线",
            "attributes": [],
            "relations": []
          },
          {
            "id": "vo-quantity",
            "name": "数量",
            "nameEn": "Quantity",
            "projectId": "manufacturing-project",
            "businessScenarioId": "scenario-mts",
            "entityRole": "child_entity",
            "parentAggregateId": "production-order",
            "description": "数量值对象",
            "attributes": [
              { "id": "vo-q-amount", "name": "数值", "nameEn": "amount", "dataType": "decimal", "required": true },
              { "id": "vo-q-unit", "name": "单位", "nameEn": "unit", "dataType": "string", "required": true }
            ],
            "relations": []
          }
        ],
        "createdAt": "2026-06-19T16:00:00.000Z",
        "updatedAt": "2026-06-19T16:00:00.000Z"
      },
      "behaviorModel": {
        "id": "bm-manufacturing",
        "name": "生产制造行为模型",
        "version": "0.1.0",
        "domain": "domain-manufacturing",
        "stateMachines": [
          {
            "id": "sm-production-order",
            "name": "生产订单生命周期",
            "entity": "production-order",
            "statusField": "status",
            "states": [
              {
                "id": "state-created",
                "name": "创建",
                "description": "初始状态",
                "isInitial": true,
                "availableActions": ["action-release-order"],
                "semanticTag": "created"
              },
              { "id": "state-released", "name": "已下达", "description": "已下达生产" },
              { "id": "state-in-progress", "name": "执行中", "description": "正在执行" },
              { "id": "state-reported", "name": "已报工", "description": "已报工" },
              { "id": "state-produced", "name": "已产出", "description": "已产出" },
              {
                "id": "state-tech-closed",
                "name": "技术关闭",
                "description": "技术关闭",
                "isFinal": true
              }
            ],
            "transitions": [
              {
                "id": "trans-release",
                "name": "下达",
                "from": "state-created",
                "to": "state-released",
                "trigger": "manual",
                "preConditions": ["rule-kitting", "rule-routing-valid"],
                "guardCondition": "kittingCheck() && routingValid()",
                "publishEventId": "evt-order-released",
                "requiresApproval": false
              }
            ]
          }
        ],
        "actions": [
          {
            "id": "action-create-order",
            "name": "创建生产订单",
            "nameEn": "CreateProductionOrder",
            "targetEntityId": "production-order",
            "actionType": "create",
            "parameters": [
              { "id": "param-material-code", "name": "物料编码", "nameEn": "material_code", "dataType": "string", "required": true }
            ]
          },
          {
            "id": "action-release-order",
            "name": "生产订单下达",
            "nameEn": "ReleaseProductionOrder",
            "targetEntityId": "production-order",
            "actionType": "execute",
            "triggerPhrases": ["下达生产订单", "release order"],
            "idempotencyKeyTemplate": "{entityId}_release_{timestamp}",
            "requiresConfirmation": true,
            "parameters": [
              { "id": "param-order-id", "name": "生产订单号", "nameEn": "order_id", "dataType": "string", "required": true }
            ],
            "preConditions": ["rule-kitting", "rule-routing-valid"]
          },
          {
            "id": "action-reserve-material",
            "name": "物料预留",
            "nameEn": "ReserveMaterial",
            "targetEntityId": "material",
            "actionType": "custom",
            "description": "事件处理器示例：响应订单已下达"
          }
        ],
        "createdAt": "2026-06-19T16:00:00.000Z",
        "updatedAt": "2026-06-19T16:00:00.000Z"
      },
      "ruleModel": {
        "id": "rm-manufacturing",
        "name": "生产制造规则模型",
        "version": "0.1.0",
        "domain": "domain-manufacturing",
        "rules": [
          {
            "id": "rule-kitting",
            "name": "物料齐套校验",
            "type": "cross_entity_validation",
            "entity": "production-order",
            "condition": {
              "type": "expression",
              "expression": "BOM 中所有物料库存余量 ≥ 工单需求量"
            },
            "errorMessage": "物料未齐套，无法下达工单",
            "severity": "error"
          },
          {
            "id": "rule-routing-valid",
            "name": "工艺路线校验",
            "type": "cross_entity_validation",
            "entity": "production-order",
            "condition": {
              "type": "expression",
              "expression": "成品必须有且仅有一条有效工艺路线，工序无环"
            },
            "errorMessage": "工艺路线无效",
            "severity": "error"
          }
        ],
        "createdAt": "2026-06-19T16:00:00.000Z",
        "updatedAt": "2026-06-19T16:00:00.000Z"
      },
      "processModel": null,
      "eventModel": {
        "id": "em-manufacturing",
        "name": "生产制造事件模型",
        "version": "0.1.0",
        "domain": "domain-manufacturing",
        "events": [
          {
            "id": "evt-order-created",
            "name": "生产订单已创建",
            "nameEn": "ProductionOrderCreated",
            "entity": "production-order",
            "trigger": "state_change",
            "isDomainEvent": true
          },
          {
            "id": "evt-order-released",
            "name": "生产订单已下达",
            "nameEn": "ProductionOrderReleased",
            "entity": "production-order",
            "trigger": "state_change",
            "isDomainEvent": true,
            "payload": [
              { "field": "order_id" },
              { "field": "status" }
            ],
            "payloadFields": ["order_id", "status"]
          },
          {
            "id": "evt-order-tech-closed",
            "name": "生产订单技术关闭",
            "nameEn": "ProductionOrderTechnicallyClosed",
            "entity": "production-order",
            "trigger": "state_change",
            "isDomainEvent": true
          }
        ],
        "subscriptions": [],
        "createdAt": "2026-06-19T16:00:00.000Z",
        "updatedAt": "2026-06-19T16:00:00.000Z"
      },
      "epcModel": {
        "chains": [
          {
            "id": "epc-po-release",
            "name": "生产订单下达链",
            "aggregateRootId": "production-order",
            "chainType": "production",
            "description": "生产订单从创建到下达的 EPC 控制流",
            "nodes": [
              {
                "id": "node-po-created",
                "nodeType": "event",
                "name": "订单已创建",
                "refType": "state",
                "refId": "state-created",
                "sortOrder": 0
              },
              {
                "id": "node-po-release",
                "nodeType": "function",
                "name": "下达生产订单",
                "refType": "action",
                "refId": "action-release-order",
                "sortOrder": 1
              }
            ],
            "edges": [
              {
                "id": "edge-po-release",
                "sourceNodeId": "node-po-created",
                "targetNodeId": "node-po-release",
                "edgeType": "control_flow",
                "label": "下达",
                "sortOrder": 0
              }
            ]
          }
        ],
        "profiles": []
      },
      "governanceModel": {
        "id": "gov-manufacturing",
        "roles": [
          {
            "id": "role-planner",
            "name": "生产计划员",
            "permissions": [
              { "objectTypeId": "production-order", "ops": ["READ", "EXECUTE"] }
            ]
          },
          {
            "id": "role-cost-accountant",
            "name": "成本会计",
            "permissions": [
              { "objectTypeId": "production-order", "ops": ["READ"] }
            ]
          }
        ],
        "fieldPermissions": [
          { "objectTypeId": "production-order", "propertyNameEn": "cost_price", "allowedRoleIds": ["role-cost-accountant"] }
        ],
        "agentPolicies": [
          {
            "id": "sandbox-prod-planner",
            "roleId": "role-planner",
            "allowedMcpTools": ["resolve_intent", "query_ontology", "execute_action"],
            "allowedAggregateRootIds": ["production-order"],
            "defaultDeny": true
          }
        ],
        "createdAt": "2026-06-19T16:00:00.000Z",
        "updatedAt": "2026-06-19T16:00:00.000Z"
      },
      "dataSourcesModel": {
        "sources": [
          {
            "id": "ds-sap-po",
            "name": "SAP 生产订单 OData",
            "type": "api",
            "boundObjectTypeId": "production-order",
            "api": {
              "baseUrl": "https://sap.example/odata/s4",
              "entitySet": "ProductionOrders",
              "authSecretRef": "secret/sap-oauth-prod"
            }
          }
        ]
      },
      "metricsModel": null,
      "organizationModel": null,
      "agentSemanticLayer": {
        "intents": [
          {
            "id": "intent-release-order",
            "name": "下达生产订单",
            "category": "workflow",
            "triggerPhrases": ["下达订单", "release production order"],
            "actionId": "action-release-order",
            "targetEntityId": "production-order",
            "slotFilling": {
              "slots": [
                {
                  "id": "slot-order-id",
                  "paramName": "order_id",
                  "displayName": "生产订单号",
                  "prompt": "请提供生产订单号",
                  "examples": ["PO-2026-001"],
                  "inferableFromContext": true
                }
              ],
              "requiredSlots": ["slot-order-id"],
              "fillOrder": ["slot-order-id"],
              "allowBatchFill": false
            },
            "priority": 10,
            "requiresConfirmation": true,
            "examples": []
          }
        ],
        "dialogContextTemplate": {
          "ttl": 3600,
          "referencedEntities": [],
          "turnCount": 0,
          "state": "idle"
        },
        "semanticRelations": [],
        "businessTerms": [],
        "errorRecoveries": [],
        "temporalValidities": [],
        "fieldMappings": [],
        "agentPolicies": [],
        "metadata": {
          "version": "0.1.0",
          "lastUpdated": "2026-06-19T16:00:00.000Z",
          "totalIntents": 1,
          "totalTerms": 0,
          "totalRelations": 0,
          "coverage": {
            "entitiesWithIntents": 1,
            "totalEntities": 6,
            "actionsWithRecovery": 0,
            "totalActions": 3
          }
        }
      },
      "createdAt": "2026-06-19T16:00:00.000Z",
      "updatedAt": "2026-06-19T16:00:00.000Z"
    }
  }
}
