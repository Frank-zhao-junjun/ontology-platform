# =============================================
# 本体模型服务平台 - 环境变量配置
# =============================================

# ==================== 基础配置 ====================
SPRING_PROFILES=dev
APP_PORT=8080

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ontology
DB_USERNAME=ontology
DB_PASSWORD=ontology123
AGE_VERSION=1.5.0

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ==================== 应用配置 ====================
# 图遍历安全配置
GRAPH_MAX_DEPTH=5
GRAPH_MAX_NODES=1000
GRAPH_TIMEOUT_MS=5000

# ==================== MCP Server 配置 ====================
MCP_PORT=3001
PLATFORM_API_KEY=dev-api-key

# 缓存配置
ONTOLOGY_CACHE_TTL=3600
OBJECT_TYPE_CACHE_TTL=1800
