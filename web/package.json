{
  "name": "projects",
  "version": "1.0.0",
  "description": "Vanilla TypeScript application with Express + Vite (HTML + CSS + TS + Node API)",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "pnpm tsx watch server/server.ts",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint",
    "start": "node dist-server/server.js",
    "ts-check": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.95.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "wouter": "^3.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4.4.1",
    "autoprefixer": "^10.4.20",
    "coze-coding-dev-sdk": "^0.7.21",
    "eslint": "^9",
    "only-allow": "^1.2.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8",
    "vite": "5.4.14"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "is-generator-function": "1.0.10"
    }
  }
}
