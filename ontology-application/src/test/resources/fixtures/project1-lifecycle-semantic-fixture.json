            "transitions": [
              {"from": "DRAFT", "to": "RELEASED", "trigger": "release"},
              {"from": "RELEASED", "to": "IN_PROGRESS", "trigger": "start_production"},
              {"from": "IN_PROGRESS", "to": "COMPLETED", "trigger": "complete"},
              {"from": "DRAFT", "to": "CANCELLED", "trigger": "cancel"}
