          }
        },
        "quality-inspection": {
          "entityId": "quality-inspection",
          "entityNameEn": "QualityInspection",
          "statusField": "result",
          "stateMachine": {
            "id": "sm-inspection-lifecycle",
            "states": [
              {"name": "PENDING", "isInitial": true, "isFinal": false},
              {"name": "PASSED", "isInitial": false, "isFinal": true},
