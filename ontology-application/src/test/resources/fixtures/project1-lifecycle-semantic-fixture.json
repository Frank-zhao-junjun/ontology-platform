          "auditTrail": [
            {"timestamp": "2026-07-01T08:00:00Z", "action": "created", "userId": "system"},
            {"timestamp": "2026-07-01T08:30:00Z", "action": "released", "userId": "planner-001"}
          ],
          "stats": {
            "avgTimeInDraft": "2.5h",
