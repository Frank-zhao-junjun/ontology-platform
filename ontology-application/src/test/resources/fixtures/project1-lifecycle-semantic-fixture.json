    "id": "p1-lifecycle-semantic-001",
    "version": "1.0.0",
    "name": "生命周期与语义层导入测试",
    "displayName": "生命周期与语义层导入测试 — 含EntityLifecycle/AgentSemanticLayer JSON",
    "description": "从 Project 1 导出的模块化 JSON，包含 EntityLifecycle 和 AgentSemanticLayer 数据",
    "source": "ontology-designer",
    "status": "DRAFT",
    "projectId": "proj-manufacturing",
