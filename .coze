[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd web && pnpm install"]
run = ["bash", "-c", "cd web && npx vite --port 5000 --host 0.0.0.0"]

[deploy]
build = ["bash", "-c", "cd web && pnpm install && pnpm run build"]
run = ["bash", "-c", "cd web && pnpm run preview -- --port 5000 --host 0.0.0.0"]
