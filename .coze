[project]
requires = ["nodejs-24"]

[dev]
build = ["bash", "-c", "cd web && pnpm install"]
run = ["bash", "-c", "cd web && PORT=5000 pnpm tsx watch server/server.ts"]

[deploy]
build = ["bash", "-c", "cd web && pnpm install && pnpm run build"]
run = ["bash", "-c", "cd web && PORT=5000 node dist/server.js"]
