[project]
entrypoint = "ontology-api/src/main/java/com/ontology/platform/OntologyApiApplication.java"

[dev]
build = ["sh", "-c", "mvn clean compile -DskipTests -q"]
run = ["sh", "-c", "mvn spring-boot:run -pl ontology-api -am -DskipTests -Dspring-boot.run.profiles=dev"]

[deploy]
build = ["sh", "-c", "mvn clean package -DskipTests -q"]
run = ["sh", "-c", "export DEPLOY_RUN_PORT=${DEPLOY_RUN_PORT:-8080} && java -Dserver.port=${DEPLOY_RUN_PORT} -Dspring.profiles.active=dev -jar ontology-api/target/ontology-api-1.0.0-SNAPSHOT.jar"]
